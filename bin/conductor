#!/usr/bin/env php
<?php

use Interop\Container\ContainerInterface;
use Symfony\Component\Console\Application;

try {
    $origWorkingDir = getcwd();
    if (!is_readable($origWorkingDir)) {
        throw new Exception('Conductor must be run from within a working directory that you have read access to.');
    }
    // Resolve the autoloader robustly. Composer's bin proxy sets
    // $GLOBALS['_composer_autoload_path'] (handles custom vendor-dir names and
    // path-repo symlinks); fall back to the conventional nested-vendor location.
    $autoloadPath = $GLOBALS['_composer_autoload_path'] ?? __DIR__ . '/../../../../vendor/autoload.php';
    require $autoloadPath;
    // Run from the project root (parent of the vendor dir) so conductor's config/
    // resolves relative to the working dir. realpath() normalises any "/bin/.."
    // segment the proxy path may contain.
    chdir(dirname(realpath($autoloadPath), 2));

    /**
     * Self-called anonymous function that creates its own scope and keep the global namespace clean.
     */
    call_user_func(function () use ($origWorkingDir) {
        /** @var ContainerInterface $container */
        $container = require 'config/container.php';

        $app = new Application('Application console');

        $config = $container->get('config');
        $commands = $config['console']['commands'];
        if ($commands) {
            foreach ($commands as $command) {
                $app->add($container->get($command));
            }
        }

        if (!empty($config['debug'])) {
            error_reporting(-1);
        }

        chdir($origWorkingDir);
        $app->run();
    });
} catch (Exception $e) {
    $message = "\n\e[1;31mAn Exception Occurred:\n"
        . $e->getMessage() . "\n"
        . $e->getTraceAsString() . "\n\n";
    while ($e = $e->getPrevious()) {
        $message .= "Previous Exception:\n"
            . $e->getMessage() . "\n"
            . $e->getTraceAsString() . "\n\n";
    }

    echo $message . "\e[1;0m";
}

